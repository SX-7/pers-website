<nav
  class="from-gray-900 to-gray-950 top-0 sticky z-50 flex w-screen flex-row bg-linear-to-r select-none"
>
  {% set nav_pages = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key, { includeSelf: true }) %}
  <a
    href="{{ (collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key) | first).url }}"
    class="group flex flex-row"
  >
    <div class="lg:p-4 md:p-3 p-2 self-center no-underline">
      <div class="hidden">Home</div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-4 md:size-5 lg:size-6 stroke-slate-500 group-hover:stroke-blue-400 ease-in-out stroke-2 transition duration-400"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
        />
      </svg>
    </div>
  </a>
  <a
    href="{{ (collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key) | last).url }}"
    class="group flex flex-row"
  >
    <div class="lg:p-4 md:p-3 p-2 self-center no-underline">
      <div class="hidden">Back</div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-4 md:size-5 lg:size-6 stroke-slate-500 group-hover:stroke-blue-400 ease-in-out stroke-2 transition duration-400"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"
        />
      </svg>
    </div>
  </a>
  <a
    href="#"
    class="min-w-0 group flex w-full shrink flex-col place-content-center"
  >
    <div
      class="md:text-left lg:p-4 md:p-3 p-2 ease-in-out group-hover:text-blue-300 text-white text-xs sm:text-sm md:text-base lg:text-xl min-w-0 grow-0 truncate text-center leading-none no-underline transition duration-400"
    >
      {{ title }}
    </div>
  </a>
